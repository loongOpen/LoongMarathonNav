<launch>
<!-- Launch file for Livox MID360 LiDAR -->
	<arg name="rviz" default="true" />
	<!-- ==================== FAST-LIO-SAM ==================== -->
	<rosparam command="load" file="$(find fast_lio_sam)/config/map.yaml" />
	<param name="feature_extract_enable" type="bool" value="0"/>
	<param name="point_filter_num" type="int" value="3"/>
	<param name="max_iteration" type="int" value="3" />
	<param name="filter_size_surf" type="double" value="0.5" />
	<param name="filter_size_map" type="double" value="0.5" />
	<param name="cube_side_length" type="double" value="1000" />
	<param name="runtime_pos_log_enable" type="bool" value="0" />
	<node pkg="fast_lio_sam" type="fastlio_sam_mapping" name="laserMapping" output="screen" />
	<!-- ==================== RTK Odom ==================== -->
	<include file="$(find rtk_odom)/launch/cal.launch" />
	<!-- ==================== Odom Fusion ==================== -->
	<include file="$(find odom_fusion)/launch/odom_fusion.launch" />
	<!-- ==================== RViz ==================== -->
	<group if="$(arg rviz)">
	<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find fast_lio_sam)/rviz_cfg/map.rviz" />
	</group>
</launch>
